<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-API-26 fallback for the launcher icon. On API 26+ the
    adaptive-icon under mipmap-anydpi-v26 wins by qualifier specificity.

    Combines the brand-colored background and the white shield/X glyph
    from the adaptive layers into a single vector drawable so we don't
    have to ship PNGs at every density bucket.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:fillColor="@color/brand_primary"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M54,30 L72,30 L60,54 L72,78 L54,78 L48,66 L42,78 L24,78 L36,54 L24,30 L42,30 L48,42 Z" />

    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.5"
        android:pathData="M54,18 L78,28 L78,58 Q78,82 54,90 Q30,82 30,58 L30,28 Z" />
</vector>
