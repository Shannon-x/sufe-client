<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Required so the connection foreground service stays alive while
         the VPN tunnel is active. specialUse is the post-Android 14
         requirement; the fallback foreground service type stays for
         older platforms. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Android 13+ runtime permission for the connection notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- VpnService.prepare() implicit dependency — declared so Play
         Console's policy scanner can spot it. -->
    <queries>
        <intent>
            <action android:name="android.net.VpnService" />
        </intent>
    </queries>

    <application
        android:name=".XboardApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Xboard"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Xboard"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- VPN tunnel service. BIND_VPN_SERVICE is the system-mandated
             permission for VpnService subclasses; the intent-filter is
             how the framework discovers it during prepare(). The service
             is its own foreground host — the sticky notification lives
             on this service's lifecycle. -->
        <service
            android:name=".vpn.XboardVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="VPN tunnel relay for the user's subscription" />
        </service>

    </application>

</manifest>
